{
  "manifest_version": 3,
  "name": "Rhetoric Lens MVP",
  "version": "0.3.0",
  "description": "Analyze rhetorical patterns on the current page using Chrome built-in AI.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Rhetoric Lens MVP",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "extractor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}